<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zaleskjn_SignupPage.SignupPage"
             Title="Signup Page">

    <VerticalStackLayout HorizontalOptions="Start">
        <HorizontalStackLayout Margin="0, 20, 0, 0">
            <Label 
                Text="Username:"
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Margin="10"
                WidthRequest="130"/>
            <Border Stroke="#CCCCCC"
                    StrokeThickness="1"
                    BackgroundColor="#FFFFFF"
                    Padding="10,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4" />
                </Border.StrokeShape>
                <Entry x:Name="entryUsername"
                       Placeholder="Enter Username..."
                       PlaceholderColor="#999999"
                       TextColor="#333333"
                       BackgroundColor="Transparent"
                       HorizontalOptions="Center"/>
            </Border>
        </HorizontalStackLayout>
        <HorizontalStackLayout Margin="0, 20, 0, 0">
            <Label 
                Text="Email:"
                VerticalOptions="Center" 
                Margin="10"
                HorizontalOptions="Start"
                WidthRequest="130"/>
            <Border Stroke="#CCCCCC"
                    StrokeThickness="1"
                    BackgroundColor="#FFFFFF"
                    Padding="10,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4" />
                </Border.StrokeShape>
                <Entry x:Name="entryEmail"
                       Placeholder="Enter Email..."
                       PlaceholderColor="#999999"
                       TextColor="#333333"
                       BackgroundColor="Transparent"
                       HorizontalOptions="Center"/>
            </Border>
        </HorizontalStackLayout>
        <HorizontalStackLayout Margin="0, 20, 0, 0">
            <Label 
                Text="Password:"
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Margin="10"
                WidthRequest="130"/>
            <Border Stroke="#CCCCCC"
                    StrokeThickness="1"
                    BackgroundColor="#FFFFFF"
                    Padding="10,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4" />
                </Border.StrokeShape>
                <Entry x:Name="enterPassword"
                       Placeholder="Enter Password..."
                       PlaceholderColor="#999999"
                       TextColor="#333333"
                       BackgroundColor="Transparent"
                       HorizontalOptions="Center"
                       IsPassword="True"/>
            </Border>
        </HorizontalStackLayout>
        <HorizontalStackLayout Margin="0, 20, 0, 0">
            <Label 
                Text="Confirm Password:"
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Margin="10"
                WidthRequest="130"/>
            <Border Stroke="#CCCCCC"
                    StrokeThickness="1"
                    BackgroundColor="#FFFFFF"
                    Padding="10,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4" />
                </Border.StrokeShape>
                <Entry x:Name="enterConfirm"
                       Placeholder="Confirm Password..."
                       PlaceholderColor="#999999"
                       TextColor="#333333"
                       BackgroundColor="Transparent"
                       HorizontalOptions="Center"
                       IsPassword="True"/>
            </Border>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>